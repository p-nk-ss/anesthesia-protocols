---
/**
 * Сигнатура сайту — живий вітальний монітор (наркозний апарат):
 * ЕКГ (відведення II) + SpO₂ (плетизмограма) + EtCO₂ (капнографія).
 * Частоти фізіологічні: ЕКГ і SpO₂ синхронні з пульсом (~72/хв), капнографія —
 * із частотою дихання (~14/хв), тож CO₂ хвиля «тече» приблизно вп'ятеро повільніше.
 * Кожен канал має «розгортку» (яскравий сегмент, що біжить), плюс скан-лінія екрана.
 * prefers-reduced-motion → статичні криві без розгортки та мерехтіння.
 */
interface Props {
  variant?: 'monitor' | 'line';
  class?: string;
}
const { variant = 'monitor', class: className } = Astro.props;

const W = 1200;
const H = 100;

function ecgPath(beats: number): string {
  const c = W / beats;
  const B = H * 0.62;
  const P = H * 0.1, R = H * 0.5, Q = H * 0.06, S = H * 0.18, T = H * 0.16;
  let d = `M0 ${B}`;
  for (let i = 0; i < beats; i++) {
    const x = i * c;
    d += ` L${x + 0.08 * c} ${B}`;
    d += ` Q${x + 0.15 * c} ${B - P} ${x + 0.22 * c} ${B}`;
    d += ` L${x + 0.3 * c} ${B}`;
    d += ` L${x + 0.33 * c} ${B + Q} L${x + 0.37 * c} ${B - R} L${x + 0.41 * c} ${B + S} L${x + 0.45 * c} ${B}`;
    d += ` L${x + 0.58 * c} ${B}`;
    d += ` Q${x + 0.7 * c} ${B - T} ${x + 0.82 * c} ${B}`;
    d += ` L${x + c} ${B}`;
  }
  return d;
}

function plethPath(cycles: number): string {
  const c = W / cycles;
  const B = H * 0.82;
  const A = H * 0.56;
  let d = `M0 ${B}`;
  for (let i = 0; i < cycles; i++) {
    const x = i * c;
    d += ` C${x + 0.04 * c} ${B} ${x + 0.07 * c} ${B - A} ${x + 0.14 * c} ${B - A * 0.96}`; // систолічний підйом
    d += ` C${x + 0.24 * c} ${B - A * 0.9} ${x + 0.28 * c} ${B - A * 0.5} ${x + 0.36 * c} ${B - A * 0.46}`; // спад
    d += ` C${x + 0.4 * c} ${B - A * 0.54} ${x + 0.44 * c} ${B - A * 0.54} ${x + 0.48 * c} ${B - A * 0.4}`; // дикротична зазубрина
    d += ` C${x + 0.62 * c} ${B - A * 0.16} ${x + 0.74 * c} ${B} ${x + 0.86 * c} ${B}`;
    d += ` L${x + c} ${B}`;
  }
  return d;
}

function capnoPath(breaths: number): string {
  const c = W / breaths;
  // top нижче (ближче до 0) = вища крива. Підняли амплітуду ≈ на 30%.
  const B = H * 0.82, top = H * 0.07;
  let d = `M0 ${B}`;
  for (let i = 0; i < breaths; i++) {
    const x = i * c;
    d += ` L${x + 0.14 * c} ${B}`;
    d += ` C${x + 0.2 * c} ${B} ${x + 0.22 * c} ${top} ${x + 0.3 * c} ${top + 6}`;
    d += ` L${x + 0.66 * c} ${top}`;
    d += ` C${x + 0.72 * c} ${top} ${x + 0.74 * c} ${B} ${x + 0.8 * c} ${B}`;
    d += ` L${x + c} ${B}`;
  }
  return d;
}

const channels =
  variant === 'line'
    ? [{ key: 'ecg', d: ecgPath(9), color: 'var(--wave)' }]
    : [
        // Пульсові канали: швидка розгортка, великий розрив пунктиру.
        { key: 'ecg', label: 'ЕКГ · II', value: '72', unit: 'уд/хв', d: ecgPath(10), color: 'var(--aqua)', sweep: '4.6s', gap: 4000, off: 4220 },
        { key: 'spo2', label: 'SpO₂ · pleth', value: '98', unit: '%', d: plethPath(10), color: 'var(--spo2)', sweep: '4.6s', gap: 4000, off: 4220 },
        // Капнографія: повільна розгортка (частота дихання) + малий розрив,
        // щоб після проходу промінь повертався вже за ~2 с.
        { key: 'co2', label: 'EtCO₂', value: '37', unit: 'mmHg', d: capnoPath(6), color: 'var(--amber)', sweep: '17s', gap: 2120, off: 2340 },
      ];
---

{
  variant === 'line' ? (
    <div class={`vline ${className ?? ''}`} aria-hidden="true">
      <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none" fill="none">
        <path class="vline__base" d={channels[0].d} stroke="var(--wave)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        <path class="vline__scan" d={channels[0].d} stroke="var(--wave)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
  ) : (
    <div class={`monitor ${className ?? ''}`} role="img" aria-label="Живий вітальний монітор: ЕКГ, SpO₂ та капнографія">
      <div class="monitor__grid" aria-hidden="true" />
      <div class="monitor__scan" aria-hidden="true" />
      <div class="monitor__flicker" aria-hidden="true" />
      <div class="monitor__channels">
        {channels.map((ch) => (
          <div class="ch" style={`--ch:${ch.color};--sweep:${ch.sweep};--gap:${ch.gap};--off:${ch.off}`}>
            <div class="ch__meta">
              <span class="ch__label">{ch.label}</span>
              <span class="ch__value">
                {ch.value}
                <small>{ch.unit}</small>
              </span>
            </div>
            <div class="ch__lane">
              <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none" fill="none">
                <path class="ch__base" d={ch.d} stroke={ch.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                <path class="ch__scan" d={ch.d} stroke={ch.color} stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          </div>
        ))}
      </div>
    </div>
  )
}

<style>
  /* ——— Тонка лінія (шапка) ——— */
  .vline {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  .vline svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .vline__base {
    opacity: 0.22;
  }
  .vline__scan {
    opacity: 0.85;
    filter: drop-shadow(0 0 4px var(--glow));
    stroke-dasharray: 140 4000;
    stroke-dashoffset: 4140;
    animation: vt-sweep 5s linear infinite;
  }

  /* ——— Повний монітор (герой) ——— */
  .monitor {
    position: relative;
    border-radius: var(--radius);
    border: 1px solid var(--border-strong);
    background: radial-gradient(120% 140% at 50% 0%, rgba(79, 227, 208, 0.05), transparent 60%),
      linear-gradient(180deg, #05100e, #071613);
    box-shadow: inset 0 0 70px rgba(0, 0, 0, 0.6), var(--shadow-1);
    overflow: hidden;
    padding: clamp(0.6rem, 1.6vw, 1rem) clamp(0.7rem, 2vw, 1.2rem);
  }
  .monitor__grid {
    position: absolute;
    inset: 0;
    --gridc: color-mix(in srgb, var(--aqua) 11%, transparent);
    background-image: repeating-linear-gradient(0deg, var(--gridc) 0 1px, transparent 1px 24px),
      repeating-linear-gradient(90deg, var(--gridc) 0 1px, transparent 1px 24px);
    mask-image: linear-gradient(180deg, transparent, #000 10%, #000 90%, transparent);
    pointer-events: none;
  }
  /* Скан-лінія екрана, що повільно проходить згори донизу. */
  .monitor__scan {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 14%;
    background: linear-gradient(180deg, transparent, rgba(79, 227, 208, 0.1) 60%, rgba(191, 246, 239, 0.18));
    border-bottom: 1px solid rgba(191, 246, 239, 0.22);
    pointer-events: none;
    animation: vt-scanline 6.5s linear infinite;
  }
  /* Дуже легке мерехтіння (не строб). */
  .monitor__flicker {
    position: absolute;
    inset: 0;
    background: rgba(79, 227, 208, 0.03);
    pointer-events: none;
    animation: vt-flicker 5s ease-in-out infinite;
  }

  .monitor__channels {
    position: relative;
    display: grid;
    gap: clamp(0.4rem, 1.4vw, 0.8rem);
  }
  .ch {
    display: grid;
    gap: 2px;
  }
  .ch__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-3);
    color: var(--ch);
  }
  .ch__label {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .ch__value {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: clamp(0.95rem, 2.6vw, 1.3rem);
    line-height: 1;
    text-shadow: 0 0 14px color-mix(in srgb, var(--ch) 55%, transparent);
    font-variant-numeric: tabular-nums;
  }
  .ch__value small {
    font-size: 0.55em;
    font-weight: 500;
    opacity: 0.7;
    margin-left: 0.25em;
    letter-spacing: 0.06em;
  }
  .ch__lane {
    height: clamp(30px, 5.2vw, 48px);
  }
  .ch__lane svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .ch__base {
    opacity: 0.34;
  }
  .ch__scan {
    opacity: 0.95;
    filter: drop-shadow(0 0 5px var(--ch)) drop-shadow(0 0 12px color-mix(in srgb, var(--ch) 45%, transparent));
    stroke-dasharray: 220 var(--gap, 4000);
    stroke-dashoffset: var(--off, 4220);
    animation: vt-sweep var(--sweep, 4.6s) linear infinite;
  }

  @keyframes vt-sweep {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes vt-scanline {
    from {
      transform: translateY(-120%);
    }
    to {
      transform: translateY(820%);
    }
  }
  @keyframes vt-flicker {
    0%, 100% { opacity: 0.5; }
    45% { opacity: 0.9; }
    55% { opacity: 0.35; }
    70% { opacity: 0.75; }
  }

  @media (prefers-reduced-motion: reduce) {
    .vline__scan,
    .ch__scan {
      animation: none;
      stroke-dasharray: none;
      stroke-dashoffset: 0;
      opacity: 0.6;
    }
    .monitor__scan,
    .monitor__flicker {
      display: none;
    }
  }
</style>
