---
/**
 * Калькулятор периопераційної інфузії: вага + голодування + інвазивність +
 * крововтрата → план інфузії (підтримка 4-2-1, дефіцит 50/25/25, хірургічні
 * втрати, заміщення крововтрати, сумарна швидкість по годинах).
 * Серверний рендер формул і полів; fluid.ts заповнює обчислені значення.
 * Працює без JS (видно формули й діапазони). Дані не залежать від мережі.
 */

const SURGICAL_CLASSES = [
  { label: 'Поверхнева (0–1 мл/кг/год)', min: 0, max: 1 },
  { label: 'Низька інвазивність (2–4)', min: 2, max: 4 },
  { label: 'Помірна (5–6)', min: 5, max: 6, selected: true },
  { label: 'Висока інвазивність (8–10)', min: 8, max: 10 },
];
---

<div class="fc" data-fluid>
  <div class="fc__bar">
    <div class="fc__field">
      <label class="fc__label" for="fc-weight">Вага</label>
      <div class="fc__input">
        <input
          id="fc-weight"
          type="number"
          inputmode="decimal"
          min="1"
          max="300"
          step="1"
          value="70"
          data-fluid-weight
          aria-label="Вага пацієнта, кг"
        />
        <span class="fc__unit">кг</span>
      </div>
    </div>

    <div class="fc__field">
      <label class="fc__label" for="fc-fasting">Голодування</label>
      <div class="fc__input">
        <input
          id="fc-fasting"
          type="number"
          inputmode="decimal"
          min="0"
          max="24"
          step="1"
          value="8"
          data-fluid-fasting
          aria-label="Тривалість голодування, годин"
        />
        <span class="fc__unit">год</span>
      </div>
    </div>

    <div class="fc__field fc__field--wide">
      <label class="fc__label" for="fc-class">Інвазивність</label>
      <select id="fc-class" class="fc__select" data-fluid-class aria-label="Клас інвазивності операції">
        {
          SURGICAL_CLASSES.map((c) => (
            <option data-min={c.min} data-max={c.max} selected={c.selected}>
              {c.label}
            </option>
          ))
        }
      </select>
    </div>

    <div class="fc__field">
      <label class="fc__label" for="fc-ebl">Крововтрата</label>
      <div class="fc__input">
        <input
          id="fc-ebl"
          type="number"
          inputmode="decimal"
          min="0"
          max="20000"
          step="50"
          value="0"
          data-fluid-ebl
          aria-label="Орієнтовна крововтрата, мл"
        />
        <span class="fc__unit">мл</span>
      </div>
    </div>
  </div>

  <section class="fc__group">
    <h3 class="fc__gtitle">План інфузії</h3>
    <div class="fc__cards">
      <div class="fc__card">
        <span class="fc__cap">Підтримка (4-2-1)</span>
        <span class="fc__val"><span data-fluid-out="maintenance">—</span> <i>мл/год</i></span>
      </div>
      <div class="fc__card">
        <span class="fc__cap">Хірургічні втрати</span>
        <span class="fc__val"><span data-fluid-out="surgical">—</span> <i>мл/год</i></span>
      </div>
      <div class="fc__card">
        <span class="fc__cap">Дефіцит голодування</span>
        <span class="fc__val"><span data-fluid-out="deficit">—</span> <i>мл</i></span>
        <span class="fc__sub">
          1-ша год <b data-fluid-out="deficit-h1">—</b> · 2-га <b data-fluid-out="deficit-h2">—</b> ·
          3-тя <b data-fluid-out="deficit-h3">—</b> мл
        </span>
      </div>
    </div>
  </section>

  <section class="fc__group">
    <h3 class="fc__gtitle">Сумарна швидкість інтраопераційно</h3>
    <div class="fc__cards">
      <div class="fc__card fc__card--accent">
        <span class="fc__cap">1-ша година</span>
        <span class="fc__val"><span data-fluid-out="hour1">—</span> <i>мл/год</i></span>
      </div>
      <div class="fc__card fc__card--accent">
        <span class="fc__cap">2-га година</span>
        <span class="fc__val"><span data-fluid-out="hour2">—</span> <i>мл/год</i></span>
      </div>
      <div class="fc__card fc__card--accent">
        <span class="fc__cap">3-тя година</span>
        <span class="fc__val"><span data-fluid-out="hour3">—</span> <i>мл/год</i></span>
      </div>
    </div>
    <p class="fc__formula">Підтримка + частка дефіциту (50 / 25 / 25 %) + хірургічні втрати.</p>
  </section>

  <section class="fc__group">
    <h3 class="fc__gtitle">Заміщення крововтрати</h3>
    <div class="fc__cards">
      <div class="fc__card">
        <span class="fc__cap">Кристалоїди 3 : 1</span>
        <span class="fc__val"><span data-fluid-out="blood-crystalloid">—</span> <i>мл</i></span>
      </div>
      <div class="fc__card">
        <span class="fc__cap">Колоїди / кров 1 : 1</span>
        <span class="fc__val"><span data-fluid-out="blood-colloid">—</span> <i>мл</i></span>
      </div>
    </div>
  </section>

  <p class="fc__note">
    Орієнтовний розрахунок. Правило 4-2-1 застосовне і для дітей. Завжди звіряйте об'єм
    і темп інфузії з клінічним станом, динамічними показниками волемії та локальним протоколом.
  </p>
</div>

<script>
  import { initFluid } from './fluid';
  document.addEventListener('astro:page-load', initFluid);
</script>

<style>
  .fc {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--sp-5);
  }

  /* Панель вводу (за зразком .inf__bar) */
  .fc__bar {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: var(--sp-3) var(--sp-4);
    padding: var(--sp-4);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--glass);
    position: sticky;
    top: 8px;
    z-index: 2;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .fc__field {
    display: grid;
    gap: 0.35rem;
  }
  .fc__field--wide {
    flex: 1 1 14rem;
  }
  .fc__label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .fc__input {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35em;
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    background: var(--surface);
    padding: 0.3rem 0.7rem;
  }
  .fc__input:focus-within {
    border-color: var(--primary);
    box-shadow: 0 0 14px -2px var(--glow);
  }
  .fc__input input {
    width: 4rem;
    border: none;
    background: transparent;
    color: var(--primary);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: var(--step-1);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .fc__input input:focus,
  .fc__input input:focus-visible {
    outline: none;
    box-shadow: none;
  }
  .fc__unit {
    font-family: var(--font-mono);
    color: var(--ink-3);
  }
  .fc__select {
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    background: var(--surface);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    padding: 0.5rem 0.7rem;
    width: 100%;
  }
  .fc__select:focus-within,
  .fc__select:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 14px -2px var(--glow);
  }

  /* Групи результатів */
  .fc__group {
    margin: 0;
  }
  .fc__gtitle {
    font-size: var(--step-0);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--primary);
    margin: 0 0 var(--sp-3);
  }
  .fc__cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: var(--sp-3);
  }
  .fc__card {
    display: grid;
    gap: 0.3rem;
    padding: var(--sp-4);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    background: var(--surface);
  }
  .fc__card--accent {
    background: var(--sev-info-soft);
    border-color: color-mix(in srgb, var(--primary) 30%, transparent);
  }
  .fc__cap {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .fc__val {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: var(--step-2);
    color: var(--ink-3);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .fc__val i {
    font-style: normal;
    font-size: var(--step--1);
    color: var(--ink-3);
  }
  .fc.is-active .fc__val {
    color: var(--primary);
  }
  .fc.is-active .fc__card--accent .fc__val {
    text-shadow: 0 0 18px var(--glow);
  }
  .fc__sub {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-3);
  }
  .fc.is-active .fc__sub b {
    color: var(--ink-2);
  }
  .fc__formula,
  .fc__note {
    margin: var(--sp-2) 0 0;
    font-size: var(--step--1);
    color: var(--ink-3);
    line-height: 1.5;
  }
</style>
