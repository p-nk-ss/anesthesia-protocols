---
/**
 * Калькулятор болюсних доз: вага пацієнта → доза (мг/мкг) і об'єм (мл).
 * Серверний рендер таблиць (дози/кг і концентрації видно без JS); dose.ts додає
 * колонки «доза» та «мл». Дані — src/lib/doses.ts.
 */
import { BOLUS_GROUPS, LOCAL_ANAESTHETICS, UNIT_LABEL, isWeightBased } from '../lib/doses';
import type { BolusDrug } from '../lib/doses';

const n = (v: number) => String(v).replace('.', ',');
const rng = (a: number, b: number) => (a === b ? n(a) : `${n(a)}–${n(b)}`);

const perKgLabel = (d: BolusDrug): string => {
  const u = UNIT_LABEL[d.unit];
  if (d.perKg) return `${rng(d.perKg.min, d.perKg.max)} ${u}/кг`;
  if (d.fixed) return `${rng(d.fixed.min, d.fixed.max)} ${u}`;
  return '—';
};
---

<div class="dc" data-dose-calc>
  <div class="dc__bar">
    <label class="dc__wlabel" for="dc-weight">Вага пацієнта</label>
    <div class="dc__wfield">
      <input
        id="dc-weight"
        type="number"
        inputmode="decimal"
        min="1"
        max="300"
        step="1"
        value="70"
        data-weight
        aria-label="Вага пацієнта, кг"
      />
      <span class="dc__wunit">кг</span>
    </div>
    <p class="dc__hint">Колонки «доза» та «мл» рахуються автоматично.</p>
  </div>

  {
    BOLUS_GROUPS.map((group) => (
      <section class="dc__group">
        <h3 class="dc__gtitle">{group.title}</h3>
        <div class="dc__scroll">
          <table class="dc__table">
            <thead>
              <tr>
                <th>Препарат</th>
                <th>Доза/кг</th>
                <th>Концентрація</th>
                <th class="dc__num">Доза</th>
                <th class="dc__num">мл</th>
              </tr>
            </thead>
            <tbody>
              {group.drugs.map((d) => (
                <tr
                  data-bolus
                  data-unit={UNIT_LABEL[d.unit]}
                  data-conc={d.concPerMl}
                  data-perkgmin={d.perKg?.min}
                  data-perkgmax={d.perKg?.max}
                  data-fixedmin={d.fixed?.min}
                  data-fixedmax={d.fixed?.max}
                  data-max={d.maxDose}
                >
                  <td>
                    <span class="dc__name">{d.name}</span>
                    {d.indication && <span class="dc__sub">{d.indication}</span>}
                    {d.note && <span class="dc__note">{d.note}</span>}
                  </td>
                  <td>
                    <span class="dc__dosekg">{perKgLabel(d)}</span>
                    {!isWeightBased(d) && <span class="dc__sub">не за вагою</span>}
                  </td>
                  <td>
                    <span class="dc__conc">{d.concLabel}</span>
                  </td>
                  <td class="dc__num dc__dose" data-dose>
                    —
                  </td>
                  <td class="dc__num dc__ml" data-ml>
                    —
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))
  }

  <section class="dc__group">
    <h3 class="dc__gtitle">Місцеві анестетики — максимальна доза</h3>
    <div class="dc__scroll">
      <table class="dc__table">
        <thead>
          <tr>
            <th>Анестетик</th>
            <th>Макс. мг/кг<br /><span class="dc__th-sub">без адр / з адр</span></th>
            <th>Концентрація</th>
            <th class="dc__num">Макс. доза</th>
            <th class="dc__num">Макс. мл</th>
          </tr>
        </thead>
        <tbody>
          {
            LOCAL_ANAESTHETICS.map((la) => (
              <tr
                data-local
                data-maxperkg={la.maxPerKg}
                data-maxperkgepi={la.maxPerKgEpi}
                data-absmax={la.absoluteMax}
                data-conc={la.concPerMl}
              >
                <td>
                  <span class="dc__name">{la.name}</span>
                  {la.absoluteMax && <span class="dc__sub">абс. макс {la.absoluteMax} мг</span>}
                </td>
                <td>
                  <span class="dc__dosekg">
                    {la.maxPerKg}
                    {la.maxPerKgEpi ? ` / ${la.maxPerKgEpi}` : ''} мг/кг
                  </span>
                </td>
                <td>
                  <span class="dc__conc">{la.concLabel}</span>
                </td>
                <td class="dc__num dc__dose" data-local-mg>
                  —
                </td>
                <td class="dc__num dc__ml" data-local-ml>
                  —
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    <p class="dc__lanote">
      Макс. об'єм наведено для стандартної концентрації; інші концентрації масштабуються
      лінійно. Слідкуй за сумарною дозою при поєднанні анестетиків — ризик системної
      токсичності.
    </p>
  </section>
</div>

<script>
  import { initDoses } from './dose';
  document.addEventListener('astro:page-load', initDoses);
</script>

<style>
  .dc {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--sp-5);
  }
  .dc__bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-3) var(--sp-4);
    padding: var(--sp-4);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--glass);
    position: sticky;
    top: 8px;
    z-index: 2;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .dc__wlabel {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .dc__wfield {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35em;
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    background: var(--surface);
    padding: 0.3rem 0.7rem;
  }
  .dc__wfield:focus-within {
    border-color: var(--primary);
    box-shadow: 0 0 14px -2px var(--glow);
  }
  .dc__wfield input {
    width: 4.5rem;
    border: none;
    background: transparent;
    color: var(--primary);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: var(--step-2);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .dc__wfield input:focus,
  .dc__wfield input:focus-visible {
    outline: none;
    box-shadow: none;
  }
  .dc__wunit {
    font-family: var(--font-mono);
    color: var(--ink-3);
  }
  .dc__hint {
    margin: 0;
    font-size: var(--step--1);
    color: var(--ink-3);
    flex: 1 1 12rem;
  }

  .dc__group {
    margin: 0;
  }
  .dc__gtitle {
    font-size: var(--step-0);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--primary);
    margin: 0 0 var(--sp-3);
  }
  .dc__scroll {
    overflow-x: auto;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    background: var(--surface);
  }
  .dc__table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--step--1);
    min-width: 36rem;
  }
  .dc__table thead th {
    position: sticky;
    top: 0;
    background: color-mix(in srgb, var(--primary) 20%, var(--surface));
    color: var(--ink);
    text-align: left;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: var(--sp-2) var(--sp-3);
    white-space: nowrap;
    vertical-align: bottom;
  }
  .dc__th-sub {
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    color: var(--ink-3);
  }
  .dc__table td {
    padding: var(--sp-2) var(--sp-3);
    border-top: 1px solid var(--border);
    vertical-align: top;
  }
  .dc__table tbody tr:nth-child(even) td {
    background: var(--surface-2);
  }
  .dc__name {
    display: block;
    font-weight: 600;
    color: var(--ink);
  }
  .dc__sub {
    display: inline-block;
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .dc__note {
    display: block;
    margin-top: 2px;
    font-size: 0.68rem;
    color: var(--ink-3);
    line-height: 1.35;
  }
  .dc__dosekg,
  .dc__conc {
    display: block;
    font-family: var(--font-mono);
    color: var(--ink-2);
    white-space: nowrap;
  }
  .dc__num {
    text-align: right;
    white-space: nowrap;
  }
  .dc__dose,
  .dc__ml {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: var(--step-0);
    color: var(--ink-3);
    font-variant-numeric: tabular-nums;
  }
  .dc.is-active .dc__dose {
    color: var(--ink);
  }
  .dc.is-active .dc__ml {
    color: var(--primary);
    text-shadow: 0 0 18px var(--glow);
  }
  .dc__lanote {
    margin: var(--sp-3) 0 0;
    font-size: var(--step--1);
    color: var(--ink-3);
    line-height: 1.5;
  }
</style>
