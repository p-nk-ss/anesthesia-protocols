---
/**
 * Вертикальна таймлінія кроків алгоритму.
 * Семантичний <ol> рендериться на сервері (читається без JS, друкується, офлайн).
 * Поява кроків — через глобальний [data-reveal]; світний rail заповнюється при
 * прокрутці (timeline.ts). Кроки можуть містити схему (figure) з відкриттям у
 * повноекранному lightbox. Усе вимикається при prefers-reduced-motion.
 */
export interface Step {
  title: string;
  body?: string;
  items?: string[];
  severity?: 'info' | 'warning' | 'critical' | 'success';
  label?: string;
  image?: string;
  imageCaption?: string;
}
interface Props {
  steps: Step[];
}
const { steps } = Astro.props;

const SEV_TEXT: Record<string, string> = {
  info: 'Крок',
  success: 'Підтвердження',
  warning: 'Увага',
  critical: 'Критично',
};
---

<div class="timeline" data-timeline>
  <span class="tl-rail" aria-hidden="true"></span>
  <span class="tl-rail__fill" aria-hidden="true"></span>

  <ol class="tl-list" data-reveal-group>
    {
      steps.map((step, i) => (
        <li class="tl-step" data-reveal data-tl-step data-severity={step.severity ?? 'info'}>
          <div class="tl-node" aria-hidden="true">
            <span class="tl-num">{i + 1}</span>
          </div>
          <div class="tl-card">
            <div class="tl-meta">
              {step.label && <span class="tl-label">{step.label}</span>}
              <span class="tl-sev">{SEV_TEXT[step.severity ?? 'info']}</span>
            </div>
            <h3 class="tl-title">{step.title}</h3>
            {step.body && <p class="tl-body">{step.body}</p>}
            {step.items && step.items.length > 0 && (
              <ul class="tl-items">
                {step.items.map((it) => (
                  <li>{it}</li>
                ))}
              </ul>
            )}
            {step.image && (
              <figure class="tl-fig">
                <button
                  type="button"
                  class="tl-fig__btn"
                  data-zoom
                  data-src={step.image}
                  aria-label={`Збільшити схему: ${step.imageCaption ?? step.title}`}
                >
                  <img src={step.image} alt={step.imageCaption ?? step.title} loading="lazy" decoding="async" />
                  <span class="tl-fig__hint">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7" /><path d="m20 20-3.2-3.2M11 8v6M8 11h6" /></svg>
                    Схема
                  </span>
                </button>
                {step.imageCaption && <figcaption>{step.imageCaption}</figcaption>}
              </figure>
            )}
          </div>
        </li>
      ))
    }
  </ol>

  <dialog class="lightbox" data-lightbox aria-label="Перегляд схеми">
    <button type="button" class="lightbox__close" data-lightbox-close aria-label="Закрити перегляд">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18" /></svg>
    </button>
    <img data-lightbox-img alt="" />
  </dialog>
</div>

<script>
  import { initTimeline } from './timeline';

  function initFigures() {
    const dlg = document.querySelector<HTMLDialogElement>('[data-lightbox]');
    if (!dlg) return;
    const img = dlg.querySelector<HTMLImageElement>('[data-lightbox-img]');
    const close = dlg.querySelector<HTMLButtonElement>('[data-lightbox-close]');

    document.querySelectorAll<HTMLButtonElement>('[data-zoom]').forEach((btn) => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        if (img) img.src = btn.dataset.src || '';
        dlg.showModal();
      });
    });
    close?.addEventListener('click', () => dlg.close());
    // Клік по тлу (поза зображенням) закриває.
    dlg.addEventListener('click', (e) => {
      if (e.target === dlg) dlg.close();
    });
  }

  document.addEventListener('astro:page-load', () => {
    initTimeline();
    initFigures();
  });
</script>
