---
import { CATEGORY_LIST } from '../lib/categories';
---

<div class="filter" role="search">
  <div class="filter__field">
    <svg class="filter__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
      <circle cx="11" cy="11" r="7"></circle>
      <path d="m20 20-3.2-3.2"></path>
    </svg>
    <input
      id="protocol-search"
      type="search"
      inputmode="search"
      autocomplete="off"
      placeholder="Пошук протоколу…"
      aria-label="Пошук протоколу за назвою або описом"
    />
  </div>
  <div class="filter__chips" role="group" aria-label="Фільтр за категорією">
    <button type="button" class="chip is-active" data-filter="all" aria-pressed="true">Усі</button>
    {
      CATEGORY_LIST.map((c) => (
        <button type="button" class="chip" data-filter={c.key} aria-pressed="false">
          {c.label}
        </button>
      ))
    }
  </div>
</div>

<p id="no-results" class="no-results" hidden>За запитом нічого не знайдено.</p>

<style>
  .filter {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-bottom: var(--sp-6);
  }
  .filter__field {
    position: relative;
    display: flex;
    align-items: center;
  }
  .filter__icon {
    position: absolute;
    left: var(--sp-4);
    color: var(--ink-3);
    pointer-events: none;
    transition: color 0.2s var(--ease);
  }
  #protocol-search {
    width: 100%;
    font: inherit;
    font-size: var(--step-0);
    color: var(--ink);
    padding: 0.95rem 1rem 0.95rem 3rem;
    background: var(--glass);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.25s var(--ease), box-shadow 0.25s var(--ease), background 0.25s var(--ease);
  }
  #protocol-search::placeholder {
    color: var(--ink-3);
  }
  #protocol-search:focus {
    outline: none;
    background: var(--glass-2);
    border-color: color-mix(in srgb, var(--primary) 55%, transparent);
    box-shadow: var(--glow-aqua);
  }
  .filter__field:focus-within .filter__icon {
    color: var(--primary);
  }

  .filter__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .chip {
    position: relative;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.03em;
    padding: 0.45em 1em;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    background: var(--glass);
    color: var(--ink-2);
    cursor: pointer;
    overflow: hidden;
    transition: color 0.25s var(--ease), border-color 0.25s var(--ease), transform 0.2s var(--spring);
  }
  /* Заливка-свип з-під лівого краю. */
  .chip::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease);
    z-index: -1;
  }
  .chip:hover {
    color: var(--primary);
    border-color: var(--primary);
  }
  .chip.is-active {
    color: var(--on-primary);
    border-color: var(--primary);
  }
  .chip.is-active::before {
    transform: scaleX(1);
  }
  .chip:active {
    transform: scale(0.96);
  }

  .no-results {
    font-family: var(--font-mono);
    color: var(--ink-2);
    font-size: var(--step-0);
    padding: var(--sp-5) 0;
  }
</style>

<script>
  function initSearchFilter() {
    const search = document.getElementById('protocol-search') as HTMLInputElement | null;
    if (!search) return; // не на цій сторінці
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-card]'));
    const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-category-section]'));
    const noResults = document.getElementById('no-results');

    let activeCategory = 'all';
    const norm = (s: string) =>
      s.toLowerCase().normalize('NFKD').replace(/\p{Diacritic}/gu, '').trim();

    function apply() {
      const q = norm(search!.value);
      let visible = 0;
      for (const card of cards) {
        const matchesCat = activeCategory === 'all' || card.dataset.category === activeCategory;
        const hay = norm((card.dataset.title ?? '') + ' ' + (card.dataset.desc ?? ''));
        const show = matchesCat && (q === '' || hay.includes(q));
        card.hidden = !show;
        if (show) visible++;
      }
      for (const sec of sections) {
        sec.hidden = sec.querySelectorAll('[data-card]:not([hidden])').length === 0;
      }
      if (noResults) noResults.hidden = visible !== 0;
    }

    search.addEventListener('input', apply);
    for (const chip of chips) {
      chip.addEventListener('click', () => {
        activeCategory = chip.dataset.filter ?? 'all';
        for (const c of chips) {
          const on = c === chip;
          c.classList.toggle('is-active', on);
          c.setAttribute('aria-pressed', String(on));
        }
        apply();
      });
    }
  }

  document.addEventListener('astro:page-load', initSearchFilter);
</script>
