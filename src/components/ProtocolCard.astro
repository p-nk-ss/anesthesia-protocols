---
import { TYPE_LABEL } from '../lib/categories';
import type { CategoryKey } from '../lib/categories';

interface Props {
  href: string;
  title: string;
  description: string;
  type: 'algorithm' | 'reference';
  category: CategoryKey;
  sourceName?: string;
}
const { href, title, description, type, category, sourceName } = Astro.props;
---

<a
  class="card"
  href={href}
  data-card
  data-title={title.toLowerCase()}
  data-desc={description.toLowerCase()}
  data-category={category}
>
  <div class="card__top">
    <span class="badge" data-type={type}>{TYPE_LABEL[type]}</span>
    {sourceName && <span class="card__source">{sourceName}</span>}
  </div>
  <h3 class="card__title">{title}</h3>
  <p class="card__desc">{description}</p>
  <span class="card__cta" aria-hidden="true">
    Відкрити
    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
  </span>
</a>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-5);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-1);
    transition: transform 0.22s var(--ease), box-shadow 0.22s var(--ease), border-color 0.22s var(--ease);
    overflow: hidden;
  }
  /* Тонка ліва межа кольору первинної палітри як акцент. */
  .card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--primary);
    opacity: 0;
    transition: opacity 0.22s var(--ease);
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-2);
    border-color: var(--border-strong);
  }
  .card:hover::before {
    opacity: 1;
  }
  .card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-2);
    margin-bottom: var(--sp-1);
  }
  .card__source {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-3);
  }
  .card__title {
    font-size: var(--step-1);
    margin: 0;
  }
  .card__desc {
    margin: 0;
    color: var(--ink-2);
    font-size: var(--step-0);
  }
  .card__cta {
    margin-top: auto;
    padding-top: var(--sp-3);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    color: var(--primary);
  }
  .card__cta svg {
    transition: transform 0.22s var(--ease);
  }
  .card:hover .card__cta svg {
    transform: translateX(3px);
  }
</style>
