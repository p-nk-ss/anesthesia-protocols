---
/**
 * Сигнатурний елемент сайту — лінія капнографії (EtCO₂).
 * Капнографія з кривою — ключовий маркер у протоколах (підтвердження інтубації
 * та вентиляції), тож вона є фірмовим мотивом усього довідника.
 */
interface Props {
  /** Анімувати «промальовування» лінії при появі. */
  animate?: boolean;
  class?: string;
}
const { animate = false, class: className } = Astro.props;
// Дві хвилі плато CO₂ (характерна «прямокутна» форма капнограми).
const d =
  'M0 26 H22 C26 26 27 8 31 8 H50 C54 8 55 26 59 26 H92 ' +
  'C96 26 97 8 101 8 H120 C124 8 125 26 129 26 H160';
---

<svg
  class={`capno ${animate ? 'capno--animate' : ''} ${className ?? ''}`}
  viewBox="0 0 160 32"
  fill="none"
  role="img"
  aria-label="Крива капнографії"
  preserveAspectRatio="none"
>
  <path d={d} stroke="var(--wave)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
</svg>

<style>
  .capno {
    display: block;
    width: 100%;
    height: 100%;
  }
  .capno--animate path {
    stroke-dasharray: 420;
    stroke-dashoffset: 420;
    animation: capno-draw 2.4s var(--ease) forwards;
  }
  @keyframes capno-draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .capno--animate path {
      animation: none;
      stroke-dashoffset: 0;
    }
  }
</style>
