---
// Перемикач світлої/темної теми. Стан зберігається у localStorage('theme').
---

<button id="theme-toggle" type="button" class="theme-toggle" aria-label="Перемкнути тему" title="Тема">
  <svg class="t-sun" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"></path>
  </svg>
  <svg class="t-moon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.5 6.5 0 0 0 9.8 9.8Z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 13px;
    border: 1px solid var(--border-strong);
    background: var(--glass);
    color: var(--ink-2);
    cursor: pointer;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: color 0.25s var(--ease), border-color 0.25s var(--ease), box-shadow 0.25s var(--ease), transform 0.2s var(--spring);
  }
  .theme-toggle:hover {
    color: var(--primary);
    border-color: var(--primary);
    box-shadow: var(--glow-aqua);
  }
  .theme-toggle:active {
    transform: scale(0.94);
  }
  .theme-toggle svg {
    grid-area: 1 / 1;
    transition: opacity 0.25s var(--ease), transform 0.4s var(--spring);
  }
  :global(:root[data-theme='dark']) .t-sun {
    opacity: 1;
    transform: rotate(0);
  }
  :global(:root[data-theme='dark']) .t-moon {
    opacity: 0;
    transform: rotate(-50deg) scale(0.5);
  }
  :global(:root[data-theme='light']) .t-sun {
    opacity: 0;
    transform: rotate(50deg) scale(0.5);
  }
  :global(:root[data-theme='light']) .t-moon {
    opacity: 1;
    transform: rotate(0);
  }
</style>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn || btn.dataset.bound === '1') return;
    btn.dataset.bound = '1';

    const root = document.documentElement;
    const meta = document.querySelector('meta[name="theme-color"]');
    const COLORS: Record<string, string> = { light: '#eaf1f0', dark: '#07120f' };
    const current = () => (root.getAttribute('data-theme') === 'light' ? 'light' : 'dark');

    btn.addEventListener('click', () => {
      const next = current() === 'light' ? 'dark' : 'light';
      root.setAttribute('data-theme', next);
      try {
        localStorage.setItem('theme', next);
      } catch {}
      if (meta) meta.setAttribute('content', COLORS[next]);
    });
  }

  document.addEventListener('astro:page-load', initThemeToggle);
</script>
