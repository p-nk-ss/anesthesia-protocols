---
/**
 * Калькулятор інфузій: вага пацієнта → швидкість мл/год для кожного препарату.
 * Серверний рендер таблиці (концентрації + дози видно без JS); infusion.ts додає
 * колонку мл/год. Дані — src/lib/infusions.ts.
 */
import { INFUSION_GROUPS, RATE_LABEL, isWeightBased } from '../lib/infusions';

const fmtRange = (min: number, max: number) =>
  (min === max ? `${min}` : `${min}–${max}`).replace(/\./g, ',');
---

<div class="inf" data-infusion>
  <div class="inf__bar">
    <label class="inf__wlabel" for="inf-weight">Вага пацієнта</label>
    <div class="inf__wfield">
      <input
        id="inf-weight"
        type="number"
        inputmode="decimal"
        min="1"
        max="300"
        step="1"
        value="70"
        data-weight
        aria-label="Вага пацієнта, кг"
      />
      <span class="inf__wunit">кг</span>
    </div>
    <p class="inf__hint">Колонка «мл/год» перераховується автоматично.</p>
  </div>

  {
    INFUSION_GROUPS.map((group) => (
      <section class="inf__group">
        <h3 class="inf__gtitle">{group.title}</h3>
        <div class="inf__scroll">
          <table class="inf__table">
            <thead>
              <tr>
                <th>Препарат</th>
                <th>Розведення</th>
                <th>Доза</th>
                <th class="inf__mlhr">мл/год</th>
              </tr>
            </thead>
            <tbody>
              {group.drugs.map((d) => (
                <tr>
                  <td>
                    <span class="inf__name">{d.name}</span>
                    {!isWeightBased(d.rate.unit) && <span class="inf__nowt">не за вагою</span>}
                  </td>
                  <td>
                    <span class="inf__recipe">{d.recipe}</span>
                    <span class="inf__conc">{d.concLabel}</span>
                  </td>
                  <td>
                    <span class="inf__dose">
                      {fmtRange(d.rate.min, d.rate.max)} {RATE_LABEL[d.rate.unit]}
                    </span>
                    {d.loading && <span class="inf__load">навантаж.: {d.loading}</span>}
                  </td>
                  <td
                    class="inf__rate"
                    data-rate
                    data-conc={d.concPerMl}
                    data-min={d.rate.min}
                    data-max={d.rate.max}
                    data-unit={d.rate.unit}
                  >
                    —
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))
  }

  <p class="inf__note">
    Перевіряйте дози за локальним протоколом. Перерахунок мл/год: доза × вага × 60 ÷
    концентрація (мкг/мл). Препарати «не за вагою» рахуються від фіксованого діапазону.
  </p>
</div>

<script>
  import { initInfusions } from './infusion';
  document.addEventListener('astro:page-load', initInfusions);
</script>

<style>
  .inf {
    display: grid;
    gap: var(--sp-5);
  }
  .inf__bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-3) var(--sp-4);
    padding: var(--sp-4);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--glass);
    position: sticky;
    top: 8px;
    z-index: 2;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .inf__wlabel {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .inf__wfield {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35em;
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    background: var(--surface);
    padding: 0.3rem 0.7rem;
  }
  .inf__wfield:focus-within {
    border-color: var(--primary);
    box-shadow: 0 0 0 1px var(--primary);
  }
  .inf__wfield input {
    width: 4.5rem;
    border: none;
    background: transparent;
    color: var(--primary);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: var(--step-2);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .inf__wfield input:focus {
    outline: none;
  }
  .inf__wunit {
    font-family: var(--font-mono);
    color: var(--ink-3);
  }
  .inf__hint {
    margin: 0;
    font-size: var(--step--1);
    color: var(--ink-3);
    flex: 1 1 12rem;
  }

  .inf__group {
    margin: 0;
  }
  .inf__gtitle {
    font-size: var(--step-0);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--primary);
    margin: 0 0 var(--sp-3);
  }
  .inf__scroll {
    overflow-x: auto;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    background: var(--surface);
  }
  .inf__table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--step--1);
    min-width: 34rem;
  }
  .inf__table thead th {
    position: sticky;
    top: 0;
    background: color-mix(in srgb, var(--primary) 20%, var(--surface));
    color: var(--ink);
    text-align: left;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: var(--sp-2) var(--sp-3);
    white-space: nowrap;
  }
  .inf__table td {
    padding: var(--sp-2) var(--sp-3);
    border-top: 1px solid var(--border);
    vertical-align: top;
  }
  .inf__table tbody tr:nth-child(even) td {
    background: var(--surface-2);
  }
  .inf__name {
    display: block;
    font-weight: 600;
    color: var(--ink);
  }
  .inf__nowt {
    display: inline-block;
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .inf__recipe {
    display: block;
    color: var(--ink-2);
  }
  .inf__conc,
  .inf__load {
    display: block;
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--ink-3);
  }
  .inf__dose {
    display: block;
    font-family: var(--font-mono);
    color: var(--ink);
    white-space: nowrap;
  }
  .inf__mlhr {
    text-align: right;
  }
  .inf__rate {
    text-align: right;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: var(--step-0);
    color: var(--ink-3);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .inf.is-active .inf__rate {
    color: var(--primary);
    text-shadow: 0 0 18px var(--glow);
  }
  .inf__note {
    margin: 0;
    font-size: var(--step--1);
    color: var(--ink-3);
    line-height: 1.5;
  }
</style>
