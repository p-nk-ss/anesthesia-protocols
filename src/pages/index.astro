---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProtocolCard from '../components/ProtocolCard.astro';
import SearchFilter from '../components/SearchFilter.astro';
import VitalsTrace from '../components/VitalsTrace.astro';
import { CATEGORY_LIST } from '../lib/categories';
import { plural } from '../lib/plural';

const all = (await getCollection('protocols')).filter((p) => !p.data.draft);
all.sort((a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title, 'uk'));

const byCategory = CATEGORY_LIST.map((cat) => ({
  ...cat,
  items: all.filter((p) => p.data.category === cat.key),
})).filter((g) => g.items.length > 0);

const total = all.length;
const totalWord = plural(total, 'протокол', 'протоколи', 'протоколів');
---

<BaseLayout>
  <section class="hero">
    <div class="container">
      <p class="eyebrow hero__eyebrow">
        <span class="hero__live"></span>Периопераційний довідник · офлайн
      </p>

      <h1 class="hero__title">
        Протоколи та алгоритми<br /><em>під рукою</em>
      </h1>

      <p class="hero__lead">
        Ключові настанови з анестезіології без пошуку файлів. Покрокові алгоритми,
        живі переходи між етапами, миттєвий доступ із телефона в операційній.
      </p>

      <div class="hero__monitor" aria-hidden="true">
        <VitalsTrace variant="hero" />
      </div>

      <dl class="readout">
        <div class="readout__ch">
          <dt>Протоколи</dt>
          <dd>{String(total).padStart(2, '0')}</dd>
        </div>
        <div class="readout__ch">
          <dt>Категорії</dt>
          <dd>{String(byCategory.length).padStart(2, '0')}</dd>
        </div>
        <div class="readout__ch">
          <dt>Доступ</dt>
          <dd class="readout__ok">офлайн</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="catalog container">
    <SearchFilter />

    {
      byCategory.map((group) => (
        <section class="cat" data-category-section data-category={group.key}>
          <header class="cat__head">
            <span class="cat__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d={group.icon} />
              </svg>
            </span>
            <div>
              <h2 class="cat__title">{group.label}</h2>
              <p class="cat__blurb">{group.blurb}</p>
            </div>
            <span class="cat__count">
              {group.items.length} {plural(group.items.length, 'протокол', 'протоколи', 'протоколів')}
            </span>
          </header>
          <div class="grid" data-reveal-group>
            {group.items.map((p) => (
              <ProtocolCard
                href={`/protocols/${p.id}`}
                title={p.data.title}
                description={p.data.description}
                type={p.data.type}
                category={p.data.category}
                sourceName={p.data.source?.name}
              />
            ))}
          </div>
        </section>
      ))
    }
  </section>

  <style>
    .hero {
      padding-block: var(--sp-8) var(--sp-7);
    }
    .hero__eyebrow {
      display: inline-flex;
      align-items: center;
      gap: var(--sp-2);
    }
    .hero__live {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--aqua);
      box-shadow: 0 0 0 0 var(--glow);
      animation: live-pulse 2.4s var(--ease) infinite;
    }
    @keyframes live-pulse {
      0% {
        box-shadow: 0 0 0 0 var(--glow);
      }
      70% {
        box-shadow: 0 0 0 8px transparent;
      }
      100% {
        box-shadow: 0 0 0 0 transparent;
      }
    }

    .hero__title {
      font-size: var(--step-5);
      line-height: 1.02;
      margin: var(--sp-4) 0 var(--sp-5);
      letter-spacing: -0.03em;
    }
    .hero__title em {
      font-style: italic;
      font-weight: 600;
      color: var(--primary);
      text-shadow: 0 0 30px var(--glow);
    }
    .hero__lead {
      max-width: 40rem;
      font-size: var(--step-1);
      color: var(--ink-2);
      line-height: 1.5;
      margin: 0;
    }

    .hero__monitor {
      margin: var(--sp-6) 0 var(--sp-5);
      height: clamp(64px, 13vw, 120px);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: linear-gradient(180deg, var(--glass), transparent);
      padding: var(--sp-3) var(--sp-4);
      overflow: hidden;
      box-shadow: inset 0 0 40px rgba(0, 0, 0, 0.2);
    }

    .readout {
      display: flex;
      flex-wrap: wrap;
      gap: var(--sp-6);
      margin: 0;
    }
    .readout__ch dt {
      font-family: var(--font-mono);
      font-size: var(--step--1);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-3);
      margin-bottom: 2px;
    }
    .readout__ch dd {
      margin: 0;
      font-family: var(--font-mono);
      font-weight: 600;
      font-size: var(--step-3);
      line-height: 1;
      color: var(--primary);
      text-shadow: 0 0 22px var(--glow);
      font-variant-numeric: tabular-nums;
    }
    .readout__ok {
      font-size: var(--step-1) !important;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--mint) !important;
    }

    .catalog {
      padding-bottom: var(--sp-7);
    }
    .cat {
      margin-top: var(--sp-8);
    }
    .cat:first-of-type {
      margin-top: var(--sp-4);
    }
    .cat__head {
      display: flex;
      align-items: center;
      gap: var(--sp-3);
      margin-bottom: var(--sp-5);
      padding-bottom: var(--sp-3);
      border-bottom: 1px solid var(--border);
    }
    .cat__icon {
      display: grid;
      place-items: center;
      width: 46px;
      height: 46px;
      flex: none;
      border-radius: 13px;
      background: var(--primary-soft);
      color: var(--primary);
      border: 1px solid color-mix(in srgb, var(--primary) 28%, transparent);
      box-shadow: 0 0 24px -8px var(--glow);
    }
    .cat__title {
      font-size: var(--step-2);
      margin: 0;
    }
    .cat__blurb {
      margin: 2px 0 0;
      color: var(--ink-3);
      font-size: var(--step--1);
    }
    .cat__count {
      margin-left: auto;
      align-self: flex-start;
      font-family: var(--font-mono);
      font-size: var(--step--1);
      letter-spacing: 0.04em;
      color: var(--ink-3);
      white-space: nowrap;
      padding-top: 4px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 19rem), 1fr));
      gap: var(--sp-4);
    }

    @media (max-width: 34rem) {
      .cat__count {
        display: none;
      }
      .readout {
        gap: var(--sp-5);
      }
    }
  </style>
</BaseLayout>
