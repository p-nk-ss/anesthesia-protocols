---
import BaseLayout from './BaseLayout.astro';
import ProtocolHero from '../components/ProtocolHero.astro';
import Timeline from '../components/Timeline.astro';
import type { Step } from '../components/Timeline.astro';
import type { CategoryKey } from '../lib/categories';
import '../styles/timeline.css';

interface Props {
  title: string;
  description: string;
  category: CategoryKey;
  updated?: Date;
  source?: { name: string; org?: string; url?: string; license?: string };
  steps: Step[];
}
const { title, description, category, updated, source, steps } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="container algo">
    <ProtocolHero
      title={title}
      description={description}
      category={category}
      type="algorithm"
      updated={updated}
      source={source}
    />
    <Timeline steps={steps} />

    {/* Довільний додатковий вміст під таймлінією (нотатки, посилання). */}
    <div class="algo__notes">
      <slot />
    </div>
  </article>

  <style>
    .algo {
      max-width: var(--maxw-read);
    }
    .algo__notes:not(:empty) {
      margin-top: var(--sp-6);
      padding-top: var(--sp-5);
      border-top: 1px solid var(--border);
      color: var(--ink-2);
      font-size: var(--step--1);
    }
  </style>
</BaseLayout>
