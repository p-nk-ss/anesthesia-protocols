---
import BaseLayout from './BaseLayout.astro';
import ProtocolHero from '../components/ProtocolHero.astro';
import type { CategoryKey } from '../lib/categories';
import '../styles/prose.css';

interface Props {
  title: string;
  description: string;
  category: CategoryKey;
  updated?: Date;
  source?: { name: string; org?: string; url?: string; license?: string };
}
const { title, description, category, updated, source } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="container ref">
    <ProtocolHero
      title={title}
      description={description}
      category={category}
      type="reference"
      updated={updated}
      source={source}
    />
    <div class="reading" data-reveal>
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>

  <style>
    .ref {
      max-width: var(--maxw-read);
    }
    .reading {
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: clamp(var(--sp-4), 4vw, var(--sp-7));
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: var(--shadow-1);
    }
  </style>
</BaseLayout>
