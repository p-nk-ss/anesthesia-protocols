---
import BaseLayout from './BaseLayout.astro';
import ProtocolHero from '../components/ProtocolHero.astro';
import type { CategoryKey } from '../lib/categories';
import '../styles/prose.css';

interface Props {
  title: string;
  description: string;
  category: CategoryKey;
  updated?: Date;
  source?: { name: string; org?: string; url?: string; license?: string };
}
const { title, description, category, updated, source } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="container ref">
    <ProtocolHero
      title={title}
      description={description}
      category={category}
      type="reference"
      updated={updated}
      source={source}
    />
    <div class="prose">
      <slot />
    </div>
  </article>

  <style>
    .ref {
      max-width: var(--maxw-read);
    }
  </style>
</BaseLayout>
